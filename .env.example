# Enables client-side Sentry error reporting when set. Users still need to
# turn error reporting on in Settings > Privacy; leaving this unset disables
# Sentry entirely regardless of that setting.
VITE_SENTRY_DSN=

# Build-time only (do not prefix with VITE_): used by @sentry/vite-plugin to
# upload source maps to Sentry during production builds. Leave unset to skip
# the upload step, e.g. for local builds.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
