{
    "$schema": "https://swc.rs/schema.json",
    "sourceMaps": true,
    "jsc": {
        "target": "es2024",
        "parser": {
            "syntax": "typescript",
            "tsx": false,
            "decorators": true,
            "dynamicImport": false
        },
        "transform": {
            "legacyDecorator": true,
            "decoratorMetadata": true
        },
        "baseUrl": ".",
        "paths": {
             "@/*": ["./src/*"]
        }
    }
}
